# ─── Microsoft Foundry ─────────────────────────────────────────────────────────
FOUNDRY_PROJECT_ENDPOINT=https://<your-foundry-project>.services.ai.azure.com/api/projects/<project>
FOUNDRY_MODEL_DEPLOYMENT_NAME=gpt-5.4

# ─── ServiceNow ────────────────────────────────────────────────────────────────
SNOW_INSTANCE_URL=https://<your-instance>.service-now.com
SNOW_USER=
SNOW_PASSWORD=
# Set "true" to use the in-memory mock client (useful for local dev / demos)
SNOWIAC_USE_MOCKS=false

# ─── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=
GITHUB_REPO=your-org/your-iac-repo
GITHUB_BASE_BRANCH=main

# ─── Azure (used by VerificationAgent only; deployment uses GH Actions OIDC) ──
AZURE_SUBSCRIPTION_ID=

# ─── Webhook auth ──────────────────────────────────────────────────────────────
WEBHOOK_HMAC_SECRET=change-me

# ─── Persistence ───────────────────────────────────────────────────────────────
# Local dev: leave DATABASE_URL blank to use SQLite at SNOWIAC_DB_PATH
SNOWIAC_DB_PATH=snowiac.db
# Cloud: set DATABASE_URL to use Postgres instead
# DATABASE_URL=postgresql://user:pass@host:5432/snowiac?sslmode=require

