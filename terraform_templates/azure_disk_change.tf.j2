# Generated by SnowIaC for ticket {{ ticket_id }}
# Requested for: {{ requested_for }}
# Description: {{ description }}
#
# This module MODIFIES an existing PremiumV2 managed disk to change its
# IOPS / throughput. It does NOT create a new disk. The Terraform `import`
# block (Terraform >= 1.5) attaches the live resource to state on first apply.
#
# Required tfvars (see terraform.auto.tfvars for ticket-derived defaults):
#   subscription_id, resource_group_name, disk_name, location, disk_size_gb,
#   storage_account_type

terraform {
  required_version = ">= 1.5"
  required_providers {
    azurerm = {
      source  = "hashicorp/azurerm"
      version = "~> 4.0"
    }
  }
}

provider "azurerm" {
  subscription_id = var.subscription_id
  features {}
}

variable "subscription_id"      { type = string }
variable "resource_group_name"  { type = string }
variable "disk_name"            { type = string }
variable "location"             { type = string }
variable "disk_size_gb"         { type = number }
variable "storage_account_type" {
  type    = string
  default = "PremiumV2_LRS"
}

# Attach the existing disk to Terraform state instead of creating a new one.
import {
  to = azurerm_managed_disk.{{ vm_name }}_data
  id = "/subscriptions/${var.subscription_id}/resourceGroups/${var.resource_group_name}/providers/Microsoft.Compute/disks/${var.disk_name}"
}

resource "azurerm_managed_disk" "{{ vm_name }}_data" {
  name                 = var.disk_name
  resource_group_name  = var.resource_group_name
  location             = var.location
  storage_account_type = var.storage_account_type
  create_option        = "Empty"   # required field; ignored on import
  disk_size_gb         = var.disk_size_gb

  # The actual change requested by ticket {{ ticket_id }}:
  disk_iops_read_write = {{ iops }}
  disk_mbps_read_write = {{ throughput_mbps }}

  tags = {
    snow_ticket = "{{ ticket_id }}"
    managed_by  = "snowiac"
  }

  # Existing disks may be zonal; we never want to recreate the disk just
  # to change zone/size/sku — only IOPS and throughput are mutable here.
  lifecycle {
    ignore_changes = [create_option, disk_size_gb, storage_account_type, zone]
  }
}

output "disk_iops" {
  value = azurerm_managed_disk.{{ vm_name }}_data.disk_iops_read_write
}

output "disk_mbps" {
  value = azurerm_managed_disk.{{ vm_name }}_data.disk_mbps_read_write
}
