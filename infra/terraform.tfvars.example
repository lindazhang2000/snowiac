# Copy to terraform.tfvars and fill in real values (terraform.tfvars is gitignored).

subscription_id = "00000000-0000-0000-0000-000000000000"
tenant_id       = "00000000-0000-0000-0000-000000000000"
location        = "eastus"

resource_group_name            = "snowiac-app-rg"
verifier_target_resource_group = "MultiAgentSnow"

github_repo     = "lindazhang2000/snowiac"          # this code repo (for image-deploy OIDC)
github_iac_repo = "lindazhang2000/snowiac"          # repo SnowIaC opens PRs in (can be the same)

foundry_project_endpoint      = "https://aif-snowiac-dev-zmzvf.services.ai.azure.com/api/projects/snowiac-intake"
foundry_account_id            = "/subscriptions/00000000-0000-0000-0000-000000000000/resourceGroups/MultiAgentSnow/providers/Microsoft.CognitiveServices/accounts/aif-snowiac-dev-zmzvf"
foundry_model_deployment_name = "gpt-5.4"
snow_instance_url             = "https://dev314131.service-now.com"
snow_user                     = "admin"

# Leave image_tag = "bootstrap" for first apply; the deploy workflow updates it.
image_tag = "bootstrap"

# Postgres ticket store. Login is fixed by the imported server; password is
# write-once at create-time and ignored on subsequent applies (managed via Key Vault).
postgres_admin_login    = "snowiacadmin"
postgres_admin_password = "REDACTED" # any non-empty string is fine post-import
